<Application x:Class="ClickStat.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClickStat.Presentation.ViewModels;assembly=ClickStat.Presentation"
             xmlns:views="clr-namespace:ClickStat.Presentation.Views;assembly=ClickStat.Presentation"
             Startup="Application_Startup"
             Exit="Application_Exit"
             ShutdownMode="OnExplicitShutdown">

    <Application.Resources>
        <vm:ViewModelLocator x:Key="ViewModelLocator"/>

        <!-- Implicit DataTemplates: WPF picks the right View for each ViewModel type -->
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
            <views:OverviewView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KeyboardViewModel}">
            <views:KeyboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MouseViewModel}">
            <views:MouseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivityViewModel}">
            <views:ActivityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WordsViewModel}">
            <views:WordsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AppsViewModel}">
            <views:AppsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Application.Resources>
</Application>
