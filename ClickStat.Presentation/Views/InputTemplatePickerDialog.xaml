<Window x:Class="ClickStat.Presentation.Views.InputTemplatePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шаблоны ввода"
        Width="560" Height="440"
        MinWidth="500" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResize"
        Topmost="True">

    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#AA17172C"/>
            <Setter Property="Foreground" Value="#D8D8F0"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBody"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBody" Property="BorderBrush" Value="#AA70FF"/>
                                <Setter TargetName="ButtonBody" Property="Background" Value="#242448"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="#303060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TinyTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#17172C"/>
            <Setter Property="Foreground" Value="#E8E8FF"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#12121E" BorderBrush="#2A2A5A" BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Шаблоны ввода" Foreground="White"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Alt + D" Foreground="#7070A0"
                               FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="&#xE711;"
                        Style="{StaticResource IconButton}"
                        Click="CloseButton_Click">
                    <Button.ToolTip>
                        <ToolTip Style="{StaticResource TinyTip}" Content="Закрыть"/>
                    </Button.ToolTip>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="#111126" CornerRadius="8"
                    BorderBrush="#333366" BorderThickness="1"
                    Padding="10,6" Margin="0,0,0,10">
                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#F2F2FF"
                         CaretBrush="#AA70FF"
                         FontSize="13"
                         Padding="0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <ListBox x:Name="TemplatesList"
                     Grid.Row="2"
                     ItemsSource="{Binding Templates}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#0E0E1C" CornerRadius="8"
                                BorderBrush="#24244A" BorderThickness="1"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding Title}"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,118,0"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Row="0" Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top">
                                    <Button Content="&#xE710;"
                                            Tag="{Binding}"
                                            Style="{StaticResource IconButton}"
                                            Click="PasteButton_Click">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource TinyTip}" Content="Вставить"/>
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="&#xE8C8;"
                                            Tag="{Binding}"
                                            Style="{StaticResource IconButton}"
                                            Click="CopyButton_Click">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource TinyTip}" Content="Копировать"/>
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="{Binding ExpandIcon}"
                                            Tag="{Binding}"
                                            Style="{StaticResource IconButton}"
                                            Click="ToggleExpandButton_Click">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource TinyTip}" Content="Развернуть"/>
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="&#xE74D;"
                                            Tag="{Binding}"
                                            Style="{StaticResource IconButton}"
                                            Background="#AA2A1820"
                                            BorderBrush="#683040"
                                            Click="DeleteButton_Click">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource TinyTip}" Content="Удалить"/>
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding DisplayText}"
                                           Foreground="#A0A0C0"
                                           FontSize="12"
                                           Margin="0,7,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="{Binding TextMaxHeight}"/>

                                <TextBlock Grid.Row="2"
                                           Text="{Binding CreatedAtLabel}"
                                           Foreground="#505070"
                                           FontSize="10"
                                           Margin="0,6,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="EmptyState"
                    Grid.Row="2"
                    Background="#0E0E1C"
                    CornerRadius="8"
                    BorderBrush="#24244A"
                    BorderThickness="1"
                    Padding="18"
                    Visibility="Collapsed">
                <TextBlock Text="Пока нет сохранённых шаблонов"
                           Foreground="#606080"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       Foreground="#AA70FF"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
