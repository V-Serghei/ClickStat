<UserControl x:Class="ClickStat.Presentation.Views.MouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>

        <!-- Stat card style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="#2E2E4E"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CardSubValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AA70FF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Scroll chip -->
        <Style x:Key="ScrollChip" TargetType="Border">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Add button style -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6A3FBB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7A4FCB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom button chip -->
        <Style x:Key="CustomBtnChip" TargetType="Border">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="#3E3E6E"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  LEFT — Mouse diagram + button stats            -->
        <!-- ═══════════════════════════════════════════════ -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">

            <!-- Mouse diagram -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                <!-- Mouse body -->
                <Border Width="150" Height="220" CornerRadius="75,75,40,40"
                        Background="#12122A" BorderBrush="#3C3C6E" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/> <!-- button zone -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Button zone: L | divider | R -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left button -->
                            <Border Grid.Column="0" CornerRadius="75,0,0,0"
                                    ToolTip="{Binding LeftButton.Count, StringFormat='Левая кнопка: {0} кликов'}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1E1E40"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2E2E55"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <TextBlock Text="Л" Foreground="#AA70FF" FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LeftButton.FormattedCount}" Foreground="#DDD"
                                               FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Divider -->
                            <Rectangle Grid.Column="1" Fill="#3C3C6E"/>

                            <!-- Right button -->
                            <Border Grid.Column="2" CornerRadius="0,75,0,0"
                                    ToolTip="{Binding RightButton.Count, StringFormat='Правая кнопка: {0} кликов'}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1E1E40"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2E2E55"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <TextBlock Text="П" Foreground="#AA70FF" FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RightButton.FormattedCount}" Foreground="#DDD"
                                               FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Body: scroll wheel + middle click -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12">
                            <!-- Scroll wheel -->
                            <Border Width="26" Height="52" CornerRadius="13"
                                    Background="#2A2A50" BorderBrush="#5555AA" BorderThickness="1.5"
                                    ToolTip="{Binding MiddleButton.Count, StringFormat='Клик колеса: {0}'}">
                                <Grid>
                                    <TextBlock Text="▲" HorizontalAlignment="Center" VerticalAlignment="Top"
                                               Foreground="#6666BB" FontSize="8" Margin="0,4"/>
                                    <TextBlock Text="▼" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                               Foreground="#6666BB" FontSize="8" Margin="0,0,0,4"/>
                                </Grid>
                            </Border>
                            <!-- Middle click count -->
                            <TextBlock Text="{Binding MiddleButton.FormattedCount}"
                                       Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,4"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- XButton1 — left side -->
                <Border Width="18" Height="36" CornerRadius="4,0,0,4"
                        Background="#252545" BorderBrush="#3C3C6E" BorderThickness="1,1,0,1"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="0,90,0,0"
                        ToolTip="{Binding BackButton.Count, StringFormat='Кнопка назад: {0}'}">
                    <TextBlock Text="◄" Foreground="#6666AA" FontSize="8"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- XButton2 — left side (below back) -->
                <Border Width="18" Height="36" CornerRadius="4,0,0,4"
                        Background="#252545" BorderBrush="#3C3C6E" BorderThickness="1,1,0,1"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="0,132,0,0"
                        ToolTip="{Binding ForwardButton.Count, StringFormat='Кнопка вперёд: {0}'}">
                    <TextBlock Text="►" Foreground="#6666AA" FontSize="8"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Standard button cards (compact) -->
            <ItemsControl>
                <ItemsControl.Items>
                    <!-- Left -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Левая кнопка" Style="{StaticResource CardLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding LeftButton.FormattedCount}"
                                       Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Right -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Правая кнопка" Style="{StaticResource CardLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding RightButton.FormattedCount}"
                                       Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Middle -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Колесо (клик)" Style="{StaticResource CardLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding MiddleButton.FormattedCount}"
                                       Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Back -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="◄ Назад" Style="{StaticResource CardLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding BackButton.FormattedCount}"
                                       Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Forward -->
                    <Border Style="{StaticResource StatCard}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="► Вперёд" Style="{StaticResource CardLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding ForwardButton.FormattedCount}"
                                       Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </ItemsControl.Items>
            </ItemsControl>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  RIGHT — Scroll stats + custom buttons          -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Scroll stats header -->
                <TextBlock Text="Прокрутка колеса" Foreground="White"
                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <!-- Up stats -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Arrow icon -->
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="#1E3A1E" Margin="0,0,16,0">
                            <TextBlock Text="▲" Foreground="#50C878" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Прокрутка ВВЕРХ" Style="{StaticResource CardLabel}"/>
                            <WrapPanel>
                                <Border Style="{StaticResource ScrollChip}" Margin="0,4,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Насечки" Style="{StaticResource CardLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding ScrollUpNotches}" Style="{StaticResource CardValue}" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ScrollChip}" Margin="0,4,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Оборотов" Style="{StaticResource CardLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding ScrollUpRotations}" Style="{StaticResource CardValue}" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ScrollChip}" Margin="0,4,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Метров пройдено" Style="{StaticResource CardLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding ScrollUpMeters, StringFormat='{}{0} м'}" Style="{StaticResource CardValue}" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Down stats -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="#3A1E1E" Margin="0,0,16,0">
                            <TextBlock Text="▼" Foreground="#FF6B6B" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Прокрутка ВНИЗ" Style="{StaticResource CardLabel}"/>
                            <WrapPanel>
                                <Border Style="{StaticResource ScrollChip}" Margin="0,4,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Насечки" Style="{StaticResource CardLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding ScrollDownNotches}" Style="{StaticResource CardValue}" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ScrollChip}" Margin="0,4,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Оборотов" Style="{StaticResource CardLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding ScrollDownRotations}" Style="{StaticResource CardValue}" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ScrollChip}" Margin="0,4,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Метров пройдено" Style="{StaticResource CardLabel}" Margin="0"/>
                                        <TextBlock Text="{Binding ScrollDownMeters, StringFormat='{}{0} м'}" Style="{StaticResource CardValue}" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Custom buttons section -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дополнительные кнопки" Foreground="White"
                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ Добавить кнопку"
                            Style="{StaticResource AddButtonStyle}"
                            Command="{Binding AddButtonCommand}"/>
                </Grid>

                <!-- Empty state -->
                <TextBlock Foreground="#555" FontSize="13" TextAlignment="Center" Margin="0,20"
                           Text="Нет добавленных кнопок. Нажмите «+ Добавить кнопку»">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CustomButtons.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Custom button chips -->
                <ItemsControl ItemsSource="{Binding CustomButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CustomBtnChip}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ButtonName}" Foreground="#C0C0C0"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FormattedCount}"
                                               Foreground="#AA70FF" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    <TextBlock Text="кликов" Foreground="#666" FontSize="10"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Loading overlay -->
                <TextBlock Text="Загрузка..." Foreground="#555" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
