<UserControl x:Class="ClickStat.Presentation.Views.ActivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ClickStat.Presentation.Converters"
             xmlns:services="clr-namespace:ClickStat.Presentation.Services"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter    x:Key="BoolToVis"/>
        <conv:IntensityToColorConverter  x:Key="IntToColor"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <TextBlock Text="{services:Loc Common.Loading}" Foreground="#A0A0C0" FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>

                <TextBlock Text="{services:Loc Activity.Title}"
                           Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                <!-- Distance card -->
                <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="12" Padding="20,16"
                        Margin="0,0,0,24" BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🖱️" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{services:Loc Activity.DistanceAllTime}"
                                       Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="12"/>
                            <TextBlock Text="{Binding DistanceLabel}"
                                       Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}" FontSize="30" FontWeight="Bold"/>
                            <TextBlock Text="{services:Loc Activity.DistanceHint}"
                                       Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- All-time weekday coefficients -->
                <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="12" Padding="16"
                        Margin="0,0,0,24" BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{services:Loc Activity.WeekdayActivity}"
                                           Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{services:Loc Activity.WeekdayHint}"
                                           Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="{services:Loc Activity.MostActiveDay}" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="11"/>
                                <TextBlock Text="{Binding MostActiveDayLabel}"
                                           Foreground="#AA70FF" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding DayStats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBackground}" CornerRadius="9" Padding="10,9"
                                            Margin="0,0,8,0" BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DayName}"
                                                       Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}" FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding CoefficientLabel}"
                                                       Foreground="#AA70FF" FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="10"
                                                       HorizontalAlignment="Center">
                                                <Run Text="{services:Loc Activity.Share}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding ShareLabel, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="10"
                                                       HorizontalAlignment="Center" Margin="0,3,0,0">
                                                <Run Text="{Binding Count, Mode=OneWay, StringFormat={}{0:N0}}"/>
                                                <Run Text=" "/>
                                                <Run Text="{services:Loc Activity.PressesShort}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Heatmap section -->
                <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="12" Padding="16"
                        BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{services:Loc Activity.HeatmapTitle}"
                                   Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="12" Margin="0,0,0,12"/>

                        <!-- Hour axis labels -->
                        <Grid Margin="50,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="0"  Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="4"  Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="8"  Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="3" Text="12" Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="4" Text="16" Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="5" Text="20" Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Heatmap grid (code-behind) -->
                        <Grid x:Name="HeatmapGrid"/>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <TextBlock Text="{services:Loc Activity.Less}" Foreground="#404060" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#0E0E1C"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#1E0E3A"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#3A1E6E"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#6A2EAA"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#9950DF"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#CC88FF"/>
                            <TextBlock Text="{services:Loc Activity.More}" Foreground="#404060" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
