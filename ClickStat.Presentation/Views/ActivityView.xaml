<UserControl x:Class="ClickStat.Presentation.Views.ActivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ClickStat.Presentation.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter    x:Key="BoolToVis"/>
        <conv:IntensityToColorConverter  x:Key="IntToColor"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <TextBlock Text="Загрузка…" Foreground="#A0A0C0" FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>

                <TextBlock Text="Активность по времени суток"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                <!-- Distance card -->
                <Border Background="#0E0E1C" CornerRadius="12" Padding="20,16"
                        Margin="0,0,0,24" BorderBrush="#2A2A5A" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🖱️" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Расстояние курсора за всё время"
                                       Foreground="#7070A0" FontSize="12"/>
                            <TextBlock Text="{Binding DistanceLabel}"
                                       Foreground="White" FontSize="30" FontWeight="Bold"/>
                            <TextBlock Text="(при стандартных 96 DPI)"
                                       Foreground="#303060" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Heatmap section -->
                <Border Background="#0E0E1C" CornerRadius="12" Padding="16"
                        BorderBrush="#1A1A3A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Тепловая карта нажатий (день × час)"
                                   Foreground="#7070A0" FontSize="12" Margin="0,0,0,12"/>

                        <!-- Hour axis labels -->
                        <Grid Margin="50,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="0"  Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="4"  Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="8"  Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="3" Text="12" Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="4" Text="16" Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="5" Text="20" Foreground="#404060" FontSize="9" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Heatmap grid (code-behind) -->
                        <Grid x:Name="HeatmapGrid"/>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <TextBlock Text="Меньше" Foreground="#404060" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#0E0E1C"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#1E0E3A"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#3A1E6E"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#6A2EAA"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#9950DF"/>
                            <Border Width="12" Height="12" CornerRadius="2" Margin="2,0" Background="#CC88FF"/>
                            <TextBlock Text="Больше" Foreground="#404060" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
