<UserControl x:Class="ClickStat.Presentation.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.Wpf"
             xmlns:presentation="clr-namespace:ClickStat.Presentation"
             xmlns:services="clr-namespace:ClickStat.Presentation.Services"
             Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Nav.Overview]}"
                       Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#151530" CornerRadius="8"
                        Padding="10,5" BorderBrush="#2A2A5A" BorderThickness="1"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="BUILD" Foreground="#606080" FontSize="10"
                                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static presentation:AppVersion.Display}"
                                   Foreground="#AA70FF" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#0E142A" CornerRadius="8"
                        Padding="12,5" BorderBrush="#2A2A5A" BorderThickness="1"
                        VerticalAlignment="Center">
                    <Border.Visibility>
                        <Binding Path="LiveIndicatorVisible">
                            <Binding.Converter>
                                <BooleanToVisibilityConverter/>
                            </Binding.Converter>
                        </Binding>
                    </Border.Visibility>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#50FF80"
                                 VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.2" Duration="0:0:0.9"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="LIVE" Foreground="#50FF80" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
            <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="10" Padding="18" Margin="0,0,12,0"
                    BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.TotalClicks]}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}"/>
                    <TextBlock Text="{Binding TotalClicks, StringFormat='{}{0:N0}'}"
                               FontSize="32" FontWeight="Bold" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="10" Padding="18" Margin="0,0,12,0"
                    BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.Today]}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}"/>
                    <TextBlock Text="{Binding ClicksToday, StringFormat='{}{0:N0}'}"
                               FontSize="32" FontWeight="Bold" Foreground="#AA70FF" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="10" Padding="18" Margin="0,0,12,0"
                    BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.MostFrequent]}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}"/>
                    <TextBlock Text="{Binding MostFrequentKey}"
                               FontSize="32" FontWeight="Bold" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="10" Padding="18"
                    BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.ErrorRate]}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{Binding ErrorRate, StringFormat='{}{0}%'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#FF8080"/>
                        <TextBlock Text=" (Backspace)" Foreground="#303060" FontSize="12"
                                   VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}" CornerRadius="10" Padding="16"
                BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.Last10Days]}"
                           Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="12" Margin="0,0,0,12"/>
                <lvc:CartesianChart Grid.Row="1"
                                    MinHeight="260"
                                    Series="{Binding DailyStatsSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Bottom"
                                    LegendTextPaint="{Binding LegendTextPaint}"
                                    TooltipPosition="Top"
                                    TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                                    TooltipTextPaint="{Binding TooltipTextPaint}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
