<UserControl x:Class="ClickStat.Presentation.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:ClickStat.Presentation.Services"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <TextBlock Text="{services:Loc Common.Loading}" Foreground="#A0A0C0" FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <TextBlock Text="{services:Loc Apps.Title}"
                           Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <Border Background="#0E0E1C" CornerRadius="12" Padding="0"
                        BorderBrush="#1A1A3A" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding Apps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,12" BorderBrush="#1A1A3A" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AppName}"
                                                       Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="#404060" FontSize="10" FontFamily="Consolas"
                                                       Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <Binding Path="ExeName" StringFormat="{}📂 {0}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,20,0" HorizontalAlignment="Right">
                                            <TextBlock Text="{services:Loc Apps.KeyPresses}" Foreground="#505080" FontSize="10"/>
                                            <TextBlock Text="{Binding KeyCount}" Foreground="#AA70FF"
                                                       FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{services:Loc Apps.MouseClicks}" Foreground="#505080" FontSize="10"/>
                                            <TextBlock Text="{Binding ClickCount}" Foreground="#70A0FF"
                                                       FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
