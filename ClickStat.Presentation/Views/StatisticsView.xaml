<UserControl x:Class="ClickStat.Presentation.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClickStat.Presentation.Views"
             xmlns:viewModels="clr-namespace:ClickStat.Presentation.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewModels:StatisticsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="CenteredDataGridText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.RowSpan="3" IsIndeterminate="True" Height="5" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <TextBlock Grid.Row="0" FontSize="24" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20">
            Статистика нажатий
        </TextBlock>

        <Border Grid.Row="1" Background="#F7F9FC" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Всего нажатий за все время: " FontSize="18" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalClicks, StringFormat={}{0:N0}}" FontSize="18" FontWeight="SemiBold" Foreground="#007ACC" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Статистика за последние 10 дней:" FontSize="16" FontWeight="Medium" Margin="0,0,0,10"/>
            
            <Border Grid.Row="1" BorderBrush="#DDE2E8" BorderThickness="1" CornerRadius="5">
                <DataGrid ItemsSource="{Binding Last10DaysStats}" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" Background="White"
                          BorderThickness="0"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EAEFF5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="*" ElementStyle="{StaticResource CenteredDataGridText}"/>
                        <DataGridTextColumn Header="Количество нажатий" Binding="{Binding Count, StringFormat={}{0:N0}}" Width="*" ElementStyle="{StaticResource CenteredDataGridText}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
