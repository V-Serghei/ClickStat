<UserControl x:Class="ClickStat.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:ClickStat.Presentation.Services"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background"      Value="{Binding Source={x:Static services:ThemeService.Instance}, Path=PanelBackground}"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
            <Setter Property="Margin"          Value="0,0,0,16"/>
            <Setter Property="BorderBrush"     Value="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SettingsHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="{services:Loc Nav.Settings}"
                       Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Appearance -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{services:Loc Settings.ThemeTitle}" Style="{StaticResource SettingsLabel}"/>
                    <TextBlock Text="{services:Loc Settings.ThemeHint}"
                               Style="{StaticResource SettingsHint}"/>
                    <CheckBox IsChecked="{Binding Source={x:Static services:ThemeService.Instance}, Path=IsLightTheme, Mode=TwoWay}"
                              Content="{services:Loc Settings.LightTheme}"
                              Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=SecondaryText}"
                              Margin="0,14,0,0"
                              FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Startup -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{services:Loc Settings.StartupTitle}" Style="{StaticResource SettingsLabel}"/>
                    <TextBlock Text="{services:Loc Settings.StartupHint}"
                               Style="{StaticResource SettingsHint}"/>
                    <CheckBox IsChecked="{Binding IsInStartup, Mode=TwoWay}"
                              Content="{services:Loc Settings.StartupCheckbox}"
                              Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=SecondaryText}"
                              Margin="0,14,0,0" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Break reminder -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{services:Loc Settings.BreakTitle}" Style="{StaticResource SettingsLabel}"/>
                    <TextBlock Text="{services:Loc Settings.BreakHint}"
                               Style="{StaticResource SettingsHint}"/>

                    <CheckBox IsChecked="{Binding BreakEnabled, Mode=TwoWay}"
                              Content="{services:Loc Settings.BreakCheckbox}"
                              Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=SecondaryText}"
                              Margin="0,16,0,12" FontSize="13"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{services:Loc Settings.Interval}"
                                   Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Text="{Binding BreakInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" FontSize="14"
                                 Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=PrimaryText}"
                                 Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBackground}"
                                 BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBorder}" BorderThickness="1"
                                 Padding="8,4"
                                 IsEnabled="{Binding BreakEnabled}"/>
                        <TextBlock Text="{services:Loc Settings.MinutesShort}" Foreground="{Binding Source={x:Static services:ThemeService.Instance}, Path=MutedText}" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{services:Loc Settings.IntervalHint}"
                               Style="{StaticResource SettingsHint}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Background image -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{services:Loc Settings.BackgroundTitle}" Style="{StaticResource SettingsLabel}"/>
                    <TextBlock Text="{services:Loc Settings.BackgroundHint}"
                               Style="{StaticResource SettingsHint}"/>

                    <!-- Preview -->
                    <Border Margin="0,14,0,0" CornerRadius="8" ClipToBounds="True"
                            Width="260" Height="100" HorizontalAlignment="Left">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{Binding Source={x:Static services:ThemeService.Instance}, Path=CardBackground}"/>
                            </Style>
                        </Border.Style>
                        <Image x:Name="BgPreview" Stretch="UniformToFill" Opacity="0.6"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="{services:Loc Settings.PickImage}" Click="PickImage_Click"
                                Background="#6A3FBB" Foreground="White" BorderThickness="0"
                                Padding="14,8" FontSize="12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#7A4FCB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="{services:Loc Common.Reset}" Click="ClearImage_Click"
                                Background="#2A2A3E" Foreground="#808080" BorderThickness="0"
                                Padding="14,8" FontSize="12" Margin="10,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="BgPathLabel" Foreground="#404060" FontSize="10"
                               Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{services:Loc Settings.AboutTitle}" Style="{StaticResource SettingsLabel}"/>
                    <TextBlock Text="{services:Loc Settings.AboutDescription}"
                               Style="{StaticResource SettingsHint}" Margin="0,8,0,2"/>
                    <TextBlock Text="{services:Loc Settings.AboutStorage}"
                               Style="{StaticResource SettingsHint}"/>
                    <TextBlock Text="{services:Loc Settings.AboutDictionary}"
                               Style="{StaticResource SettingsHint}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
