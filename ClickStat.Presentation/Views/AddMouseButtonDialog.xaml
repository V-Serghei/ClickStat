<Window x:Class="ClickStat.Presentation.Views.AddMouseButtonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить кнопку мыши"
        Width="400" Height="280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize">

    <Border CornerRadius="10" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🖱️  Добавить кнопку мыши"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White"/>
            </StackPanel>

            <!-- Phase 1: Waiting for press -->
            <StackPanel x:Name="WaitingPanel" Grid.Row="1" VerticalAlignment="Center">
                <TextBlock x:Name="WaitingLabel"
                           Text="Нажмите любую кнопку мыши, которую хотите добавить..."
                           Foreground="#A0A0A0" FontSize="14" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
                <Border x:Name="CountdownBorder" Width="60" Height="60" CornerRadius="30"
                        Background="#252540" BorderBrush="#AA70FF" BorderThickness="2"
                        HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock x:Name="CountdownLabel" Text="..." FontSize="22" FontWeight="Bold"
                               Foreground="#AA70FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Phase 2: Name entry -->
            <StackPanel x:Name="NameEntryPanel" Grid.Row="1" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock x:Name="DetectedLabel" Text="" Foreground="#A0A0A0" FontSize="12"
                           Margin="0,0,0,12" HorizontalAlignment="Center"/>

                <TextBlock Text="Название кнопки:" Foreground="#C0C0C0" FontSize="13" Margin="0,0,0,6"/>
                <Border Background="#2A2A3E" CornerRadius="6" BorderBrush="#555" BorderThickness="1">
                    <TextBox x:Name="NameTextBox"
                             Background="Transparent" Foreground="White" CaretBrush="White"
                             BorderThickness="0" FontSize="14" Padding="10,8"
                             VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Отмена" Click="CancelButton_Click"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Background="#2A2A2A" Foreground="#A0A0A0"
                        BorderBrush="#555" BorderThickness="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="OkButton" Content="Сохранить" Click="OkButton_Click"
                        Width="100" Height="34" IsEnabled="False"
                        Background="#6A3FBB" Foreground="White"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7A4FCB"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
