<UserControl x:Class="ClickStat.Presentation.Views.GamepadsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:ClickStat.Presentation.Services"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6A3FBB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7A4FCB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#5830A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleViewStyle" TargetType="Button" BasedOn="{StaticResource AddButtonStyle}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2A2A50"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisualMode}" Value="True">
                    <Setter Property="Background" Value="#3A3070"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeviceCard" TargetType="Border">
            <Setter Property="Background" Value="#0E0E1C"/>
            <Setter Property="BorderBrush" Value="#202052"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="#171732"/>
            <Setter Property="BorderBrush" Value="#2A2A60"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="AxisBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="7"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#202040"/>
            <Setter Property="Foreground" Value="#AA70FF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ButtonChip" TargetType="Border">
            <Setter Property="Background" Value="#1C1C38"/>
            <Setter Property="BorderBrush" Value="#34346E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPressed}" Value="True">
                    <Setter Property="Background" Value="#3B246A"/>
                    <Setter Property="BorderBrush" Value="#AA70FF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#AA70FF" BlurRadius="14" ShadowDepth="0" Opacity="0.45"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Shared style for buttons in the visual controller layout.
             DataContext must be GamepadButtonViewModel so IsPressed DataTrigger works. -->
        <Style x:Key="CtrlBtn" TargetType="Border">
            <Setter Property="Background" Value="#1C1C38"/>
            <Setter Property="BorderBrush" Value="#34346E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPressed}" Value="True">
                    <Setter Property="Background" Value="#3B246A"/>
                    <Setter Property="BorderBrush" Value="#AA70FF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#AA70FF" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{services:Loc Nav.Gamepads}" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#68689A" FontSize="12" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{services:Loc Gamepads.AddGamepad}"
                            Command="{Binding AddGamepadCommand}"
                            Style="{StaticResource AddButtonStyle}"
                            VerticalAlignment="Top"/>
                </Grid>

                <Border Background="#111126" BorderBrush="#252560" BorderThickness="1"
                        CornerRadius="14" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Xbox" Foreground="#AA70FF" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="{services:Loc Gamepads.XboxDescription}" Foreground="#6F6FA0" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock Text="PlayStation" Foreground="#70A0FF" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="{services:Loc Gamepads.PlayStationDescription}" Foreground="#6F6FA0" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Generic" Foreground="#50C878" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="{services:Loc Gamepads.GenericDescription}" Foreground="#6F6FA0" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#0E0E1C" BorderBrush="#202052" BorderThickness="1"
                        CornerRadius="16" Padding="28" Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasGamepads}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{services:Loc Gamepads.NoneTitle}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{services:Loc Gamepads.NoneHint}"
                                   Foreground="#6F6FA0" FontSize="12" TextAlignment="Center" TextWrapping="Wrap"
                                   MaxWidth="560" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Gamepads}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource DeviceCard}" Width="460">
                                <StackPanel>

                                    <!-- Card header: name + toggle button + profile badge + connection badge -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ProfileDescription}" Foreground="#69699A" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,4,10,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <Button Content="{Binding ToggleViewText}"
                                                    Command="{Binding ToggleViewCommand}"
                                                    Style="{StaticResource ToggleViewStyle}"
                                                    HorizontalAlignment="Right" Margin="0,0,0,8"/>
                                            <Border Background="#1A1A3A" BorderBrush="#35357A" BorderThickness="1"
                                                    CornerRadius="10" Padding="10,6" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding ProfileName}" Foreground="#CCAAFF" FontSize="12" FontWeight="Bold"/>
                                            </Border>
                                            <Border CornerRadius="8" Padding="9,5" Margin="0,8,0,0" HorizontalAlignment="Right">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#3A1E1E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Background" Value="#143A24"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ConnectionText}" FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FF7070"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                    <Setter Property="Foreground" Value="#50FF82"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ═══ STATS VIEW ═══ -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisualMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <WrapPanel Margin="0,0,0,8">
                                            <Border Style="{StaticResource MetricCard}">
                                                <StackPanel>
                                                    <TextBlock Text="{services:Loc Gamepads.ButtonPresses}" Foreground="#606090" FontSize="10"/>
                                                    <TextBlock Text="{Binding TotalButtonPresses}" Foreground="#AA70FF" FontSize="19" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricCard}">
                                                <StackPanel>
                                                    <TextBlock Text="{services:Loc Gamepads.StickMoves}" Foreground="#606090" FontSize="10"/>
                                                    <TextBlock Text="{Binding TotalStickMoves}" Foreground="#70A0FF" FontSize="19" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Background="#12122A" CornerRadius="12" Padding="12" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="{services:Loc Gamepads.LeftStick}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding LeftStickText}" Foreground="#8080B0" FontSize="11" Margin="0,4,0,8"/>
                                                    <TextBlock Text="X" Foreground="#56568A" FontSize="10"/>
                                                    <ProgressBar Value="{Binding LeftXBar, Mode=OneWay}" Style="{StaticResource AxisBar}"/>
                                                    <TextBlock Text="Y" Foreground="#56568A" FontSize="10" Margin="0,8,0,0"/>
                                                    <ProgressBar Value="{Binding LeftYBar, Mode=OneWay}" Style="{StaticResource AxisBar}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Background="#12122A" CornerRadius="12" Padding="12" Margin="8,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="{services:Loc Gamepads.RightStick}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding RightStickText}" Foreground="#8080B0" FontSize="11" Margin="0,4,0,8"/>
                                                    <TextBlock Text="X" Foreground="#56568A" FontSize="10"/>
                                                    <ProgressBar Value="{Binding RightXBar, Mode=OneWay}" Style="{StaticResource AxisBar}"/>
                                                    <TextBlock Text="Y" Foreground="#56568A" FontSize="10" Margin="0,8,0,0"/>
                                                    <ProgressBar Value="{Binding RightYBar, Mode=OneWay}" Style="{StaticResource AxisBar}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Background="#12122A" CornerRadius="12" Padding="12" Margin="0,0,0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding LeftTriggerText, StringFormat='LT / L2  {0}'}" Foreground="#A8A8D0" FontSize="11"/>
                                                    <ProgressBar Value="{Binding LeftTriggerBar, Mode=OneWay}" Style="{StaticResource AxisBar}" Margin="0,6,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding RightTriggerText, StringFormat='RT / R2  {0}'}" Foreground="#A8A8D0" FontSize="11"/>
                                                    <ProgressBar Value="{Binding RightTriggerBar, Mode=OneWay}" Style="{StaticResource AxisBar}" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{services:Loc Gamepads.Buttons}" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Buttons}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ButtonChip}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" Foreground="#E8E8FF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- ═══ VISUAL VIEW ═══ -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisualMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- Xbox controller layout (Canvas 420×215) -->
                                        <Canvas Width="420" Height="215" HorizontalAlignment="Center">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfileName}" Value="Xbox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>

                                            <!-- Subtle controller body silhouette -->
                                            <Border Canvas.Left="60" Canvas.Top="28" Width="300" Height="90"
                                                    Background="#0A0A1E" CornerRadius="18" Opacity="0.6"/>
                                            <Border Canvas.Left="0" Canvas.Top="52" Width="120" Height="130"
                                                    Background="#0A0A1E" CornerRadius="18" Opacity="0.5"/>
                                            <Border Canvas.Left="300" Canvas.Top="52" Width="120" Height="130"
                                                    Background="#0A0A1E" CornerRadius="18" Opacity="0.5"/>

                                            <!-- LT -->
                                            <Border Canvas.Left="5" Canvas.Top="2" Width="76" Height="32" CornerRadius="8"
                                                    DataContext="{Binding BtnLT}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- LB -->
                                            <Border Canvas.Left="5" Canvas.Top="38" Width="76" Height="22" CornerRadius="6"
                                                    DataContext="{Binding BtnLB}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8FF" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- RT -->
                                            <Border Canvas.Left="339" Canvas.Top="2" Width="76" Height="32" CornerRadius="8"
                                                    DataContext="{Binding BtnRT}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- RB -->
                                            <Border Canvas.Left="339" Canvas.Top="38" Width="76" Height="22" CornerRadius="6"
                                                    DataContext="{Binding BtnRB}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8FF" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Back -->
                                            <Border Canvas.Left="168" Canvas.Top="74" Width="36" Height="22" CornerRadius="7"
                                                    DataContext="{Binding BtnBack}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#C0C0E0" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="8" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Start -->
                                            <Border Canvas.Left="216" Canvas.Top="74" Width="36" Height="22" CornerRadius="7"
                                                    DataContext="{Binding BtnStart}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#C0C0E0" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="8" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Left Stick (68×68 circle canvas, positioned at 95,58) -->
                                            <Canvas Canvas.Left="95" Canvas.Top="58" Width="68" Height="68">
                                                <Ellipse Width="68" Height="68" Fill="#0D0D20" Stroke="#2A2A5A" StrokeThickness="2"/>
                                                <Ellipse Width="18" Height="18" Canvas.Left="25" Canvas.Top="25" Fill="#181838"/>
                                                <Ellipse Width="14" Height="14"
                                                         Canvas.Left="{Binding LeftStickDotX}"
                                                         Canvas.Top="{Binding LeftStickDotY}"
                                                         Fill="#AA70FF">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#AA70FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Canvas>

                                            <!-- LS button (below left stick) -->
                                            <Border Canvas.Left="97" Canvas.Top="131" Width="60" Height="18" CornerRadius="5"
                                                    DataContext="{Binding BtnLS}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#C0C0E0" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="8" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Right Stick (68×68 circle canvas, positioned at 255,65) -->
                                            <Canvas Canvas.Left="255" Canvas.Top="65" Width="68" Height="68">
                                                <Ellipse Width="68" Height="68" Fill="#0D0D20" Stroke="#2A2A5A" StrokeThickness="2"/>
                                                <Ellipse Width="18" Height="18" Canvas.Left="25" Canvas.Top="25" Fill="#181838"/>
                                                <Ellipse Width="14" Height="14"
                                                         Canvas.Left="{Binding RightStickDotX}"
                                                         Canvas.Top="{Binding RightStickDotY}"
                                                         Fill="#AA70FF">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#AA70FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Canvas>

                                            <!-- RS button (below right stick) -->
                                            <Border Canvas.Left="257" Canvas.Top="138" Width="60" Height="18" CornerRadius="5"
                                                    DataContext="{Binding BtnRS}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#C0C0E0" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="8" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- D-pad Up -->
                                            <Border Canvas.Left="36" Canvas.Top="108" Width="24" Height="24" CornerRadius="4"
                                                    DataContext="{Binding BtnDUp}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="▲" Foreground="#C0C0E0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- D-pad Down -->
                                            <Border Canvas.Left="36" Canvas.Top="156" Width="24" Height="24" CornerRadius="4"
                                                    DataContext="{Binding BtnDDown}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="▼" Foreground="#C0C0E0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- D-pad Left -->
                                            <Border Canvas.Left="12" Canvas.Top="132" Width="24" Height="24" CornerRadius="4"
                                                    DataContext="{Binding BtnDLeft}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="◀" Foreground="#C0C0E0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- D-pad Right -->
                                            <Border Canvas.Left="60" Canvas.Top="132" Width="24" Height="24" CornerRadius="4"
                                                    DataContext="{Binding BtnDRight}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="▶" Foreground="#C0C0E0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Y button — yellow, top of ABXY diamond -->
                                            <Border Canvas.Left="336" Canvas.Top="94" Width="28" Height="28" CornerRadius="14"
                                                    DataContext="{Binding BtnY}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#FFD700" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- X button — blue, left of diamond -->
                                            <Border Canvas.Left="312" Canvas.Top="116" Width="28" Height="28" CornerRadius="14"
                                                    DataContext="{Binding BtnX}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#00ADEF" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- B button — red, right of diamond -->
                                            <Border Canvas.Left="360" Canvas.Top="116" Width="28" Height="28" CornerRadius="14"
                                                    DataContext="{Binding BtnB}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E05050" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- A button — green, bottom of diamond -->
                                            <Border Canvas.Left="336" Canvas.Top="138" Width="28" Height="28" CornerRadius="14"
                                                    DataContext="{Binding BtnA}" Style="{StaticResource CtrlBtn}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#50C050" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Trigger analog fill bars -->
                                            <StackPanel Canvas.Left="5" Canvas.Top="190" Width="76" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="L" Foreground="#56568A" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <ProgressBar Value="{Binding LeftTriggerBar, Mode=OneWay}"
                                                             Style="{StaticResource AxisBar}" Width="58" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Canvas.Left="339" Canvas.Top="190" Width="76" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="R" Foreground="#56568A" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <ProgressBar Value="{Binding RightTriggerBar, Mode=OneWay}"
                                                             Style="{StaticResource AxisBar}" Width="58" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Canvas>

                                        <!-- Generic / PlayStation visual layout — just the button grid -->
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfileName}" Value="Xbox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="{services:Loc Gamepads.Buttons}" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding Buttons}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource ButtonChip}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" Foreground="#E8E8FF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Count}" Foreground="#AA70FF" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
