<Window x:Class="ClickStat.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ClickStat.Presentation.Views"
        xmlns:vm="clr-namespace:ClickStat.Presentation.ViewModels"
        xmlns:services="clr-namespace:ClickStat.Presentation.Services"
        Title="ClickStat" Height="720" Width="1280"
        MinHeight="600" MinWidth="960"
        Icon="Assets/icon.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        DataContext="{Binding Main, Source={x:Static vm:ViewModelLocator.Current}}">

    <Window.Resources>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="#606080"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"         Value="42"/>
            <Setter Property="Height"        Value="30"/>
            <Setter Property="Focusable"     Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#20204A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarMenuItemButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D8D8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Body"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Body" Property="Background" Value="#25254A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarIconButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,3,8,3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#17172C"/>
            <Setter Property="Foreground" Value="#D8D8F0"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Body"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Body" Property="BorderBrush" Value="#AA70FF"/>
                                <Setter TargetName="Body" Property="Background" Value="#202040"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Body" Property="Background" Value="#2A2450"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarPillButton" TargetType="ToggleButton">
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="82"/>
            <Setter Property="Margin" Value="0,3,8,3"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#17172C"/>
            <Setter Property="Foreground" Value="#D8D8F0"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Body"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock Text="⌄" Foreground="#AA70FF" Margin="7,-1,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Body" Property="BorderBrush" Value="#AA70FF"/>
                                <Setter TargetName="Body" Property="Background" Value="#202040"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Body" Property="BorderBrush" Value="#AA70FF"/>
                                <Setter TargetName="Body" Property="Background" Value="#202040"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=WindowBackground}"
            BorderBrush="{Binding Source={x:Static services:ThemeService.Instance}, Path=WindowBorder}"
            BorderThickness="1">
        <Grid>
            <!-- Background image: very low opacity, user-configurable from Settings -->
            <Image x:Name="BgImage"
                   Source="{Binding SettingsVm.BackgroundUri}"
                   Stretch="UniformToFill" Opacity="0.05"
                   Panel.ZIndex="0"/>

            <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>  <!-- title bar -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────────────── -->
            <Grid Grid.Row="0"
                  Background="{Binding Source={x:Static services:ThemeService.Instance}, Path=TitleBarBackground}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>  <!-- sidebar width -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App name in title bar (sidebar zone) -->
                <TextBlock Grid.Column="0" Text="ClickStat"
                           Foreground="#AA70FF" FontWeight="Bold" FontSize="12"
                           VerticalAlignment="Center" Margin="18,0"/>

                <!-- Current page title -->
                <TextBlock Grid.Column="1"
                           Foreground="#404060" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0"/>

                <!-- Window buttons -->
                <Grid Grid.Column="2">
                    <ToggleButton x:Name="UiLanguageButton"
                                  Content="{Binding Loc.CurrentLanguageLabel}"
                                  Style="{StaticResource TopBarPillButton}"
                                  IsChecked="{Binding IsOpen, ElementName=UiLanguagePopup, Mode=TwoWay}"/>

                    <Popup x:Name="UiLanguagePopup"
                           PlacementTarget="{Binding ElementName=UiLanguageButton}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           PopupAnimation="Fade">
                        <Border Background="#17172C"
                                BorderBrush="#333366"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="5"
                                MinWidth="{Binding ActualWidth, ElementName=UiLanguageButton}">
                            <ItemsControl ItemsSource="{Binding Loc.Languages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayName}"
                                                Tag="{Binding Code}"
                                                Style="{StaticResource TopBarMenuItemButton}"
                                                Click="UiLanguageItem_Click"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>

                <Button Grid.Column="3"
                        Content="{Binding Source={x:Static services:ThemeService.Instance}, Path=ThemeIcon}"
                        Command="{Binding Source={x:Static services:ThemeService.Instance}, Path=ToggleThemeCommand}"
                        ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.ToggleTheme]}"
                        Style="{StaticResource TopBarIconButton}"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="—" Style="{StaticResource WinBtn}" Click="MinimizeButton_Click"/>
                    <Button Content="🗖" Style="{StaticResource WinBtn}" Click="MaximizeButton_Click"/>
                    <Button Content="✕" Style="{StaticResource CloseBtn}" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── Main area ──────────────────────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <views:SidebarView Grid.Column="0"
                                   DataContext="{Binding}"/>

                <!-- Separator -->
                <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right"
                            Fill="#1A1A3A"/>

                <!-- Page content — WPF picks the right View via DataTemplates in App.xaml -->
                <ContentControl Grid.Column="1"
                                Content="{Binding CurrentPageVm}"/>
            </Grid>
            </Grid> <!-- inner panel.zindex grid -->
        </Grid>
    </Border>
</Window>
